# Local/dev configuration for docker-mailserver. See docs:
# https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
OVERRIDE_HOSTNAME=mail.split-even-wiser.local
PERMIT_DOCKER=network
SSL_TYPE=self-signed
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=0
ENABLE_POSTGREY=0
ONE_DIR=1
DMS_VMAIL_UID=5000
DMS_VMAIL_GID=5000
